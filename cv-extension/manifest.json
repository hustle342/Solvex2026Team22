{
  "manifest_version": 3,
  "name": "RecruitAI Gmail CV Analyzer",
  "description": "Gmail'deki PDF CV eklerini FastAPI backend'e gönderir ve analizi Chrome yan panelinde gösterir.",
  "version": "1.0.0",
  "minimum_chrome_version": "116",
  "permissions": [
    "sidePanel",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://mail.google.com/*",
    "https://*.googleusercontent.com/*",
    "http://127.0.0.1:*/*",
    "http://localhost:*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*"
      ],
      "js": [
        "content_script.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidebar/sidebar.html"
  },
  "action": {
    "default_title": "RecruitAI CV Panelini Ac"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
